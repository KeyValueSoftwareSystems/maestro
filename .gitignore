# keyvalue-skills — ignored, regenerable/local
# NOTE: git has no inline comments — keep each pattern on its own line.

# NOTE: .maestro/<slug>/ (feature requirement + all generated artifacts) is
# intentionally NOT ignored — it is git-tracked for now.

# installed skills (Claude Code / Cursor). Source of truth is ./skills/;
# these dirs are populated by install.sh (npx skills). Regenerable — never the source.
.claude/skills/
.cursor/skills/

# Python bytecode (from workflows/*.py helpers + their tests)
__pycache__/
*.pyc
