# keyvalue-skills — ignored, regenerable/local
# NOTE: git has no inline comments — keep each pattern on its own line.

# NOTE: .maestro/runs/<slug>/ (feature requirement + all generated artifacts) is
# intentionally NOT ignored — it is git-tracked for now.

# installed copies (Claude Code / Cursor). Sources of truth are ./skills/,
# ./commands/, ./agents/; these dirs are populated by install.sh. Never the source.
.claude/skills/
.claude/commands/
.claude/agents/
.cursor/skills/
.cursor/commands/

# Python bytecode (from workflows/*.py helpers + their tests)
__pycache__/
*.pyc

# lock file written locally by `npx skills add` (consumer-side artifact)
skills-lock.json
