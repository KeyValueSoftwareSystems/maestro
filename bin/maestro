#!/usr/bin/env bash
# =============================================================================
# maestro — run the KeyValue AI-SDLC pipeline by feature slug
# =============================================================================
# Drop your PRD at features/<slug>/prd.md, then from your repo root:
#
#   maestro <slug>                              # default pipeline (workflows/main.yaml)
#   maestro <slug> --path=workflows/design.yaml # run any individual/custom workflow
#   maestro <slug> --path=wf/custom.yaml -- --dry-run   # extra flags pass to conductor
#
# The default workflow is workflows/main.yaml; override it with --path=<file>
# (must come right after the slug). Anything after `--` is forwarded verbatim to
# `conductor run`.
#
# Deterministic dashboard: reads workflows/maestro.config.yaml `web.port`
#   (default 8080) and passes it as Conductor's --web-port CLI flag.
# Models: per-agent, set in workflows/maestro.config.yaml `models.agents`. This
#   wrapper passes them as --input model='{"<agent>":"<id>", …}'. Agents not listed
#   (and a plain `conductor run` without this wrapper) fall back to claude-haiku-4-5.
# =============================================================================
set -uo pipefail

slug="${1:?usage: maestro <slug> [--path=<workflow.yaml>] [-- conductor-args]}"; shift

# Default workflow; override with --path (as the first arg after the slug).
wf="workflows/main.yaml"
case "${1:-}" in
  --path=*) wf="${1#--path=}"; shift ;;
  --path)   wf="${2:?maestro: --path needs a value}"; shift 2 ;;
esac
[ "${1:-}" = "--" ] && shift   # optional separator before conductor pass-through flags

if [ ! -f "$wf" ]; then
  echo "maestro: workflow not found: $wf" >&2
  echo "         run from your repo root, or pass --path=<valid workflow file>." >&2
  exit 1
fi

# Per-agent models: build a JSON object from maestro.config.yaml `models.agents`
# and pass it as --input model='{"<agent>":"<id>", …}'. Each agent's model: line
# falls back to claude-haiku-4-5 for any key we don't send, so an empty/absent map
# is harmless. awk scopes to the `agents:` block under `models:` (4-space children).
cfg="$(dirname "$wf")/maestro.config.yaml"; [ -f "$cfg" ] || cfg="workflows/maestro.config.yaml"
model_json="{}"
if [ -f "$cfg" ]; then
  # Portable awk (no {n} interval regexes — BSD awk lacks them). `indent` = leading
  # spaces; an `agents:` child is any deeper-indented `key: value` under `models:`.
  model_json=$(awk '
    { indent = match($0, /[^ ]/) - 1 }                        # leading-space count (0 for blank)
    /^models:/                    { in_models=1; next }
    in_models && indent==0 && /[^ ]/ { in_models=0; in_agents=0 }  # dedent out of models:
    in_models && $1=="agents:"    { in_agents=1; agent_indent=indent; next }
    in_agents {
      if (!/[^ ]/ || $1 ~ /^#/) next                          # blank / comment
      if (indent <= agent_indent) { in_agents=0 }             # dedent out of agents:
      else {
        line=$0; sub(/^ +/, "", line)
        key=line; sub(/:.*/, "", key)
        val=line; sub(/^[^:]*:[ ]*/, "", val); sub(/[ ]*#.*/, "", val); sub(/ +$/, "", val)
        if (key != "" && val != "")
          items = items (items ? "," : "") "\"" key "\":\"" val "\""
        next
      }
    }
    END { printf "{%s}", items }
  ' "$cfg")
fi

# Dashboard port: maestro.config.yaml `web.port`, else 8080. The web UI binds this
# via Conductor's --web-port CLI flag (it is NOT a workflow input — the schema has
# no such key and Conductor reads it before any workflow runs).
web_port=8080
if [ -f "$cfg" ]; then
  p=$(awk '/^web:/{w=1;next} w&&/^[^[:space:]]/{w=0} w&&$1=="port:"{print $2; exit}' "$cfg")
  [ -n "$p" ] && web_port="$p"
fi

prd="features/${slug}/prd.md"
[ -s "$prd" ] || echo "maestro: WARN — $prd is missing or empty. Create it, or pass --input prd_path=... after --." >&2

if ! command -v conductor >/dev/null 2>&1; then
  echo "maestro: 'conductor' not found on PATH — it orchestrates the workflows." >&2
  echo "         If you just installed it, open a NEW terminal (or run: hash -r) so this" >&2
  echo "         shell picks up the updated PATH, then retry." >&2
  echo "         Otherwise install it (needs uv), then re-run:" >&2
  echo "           uv tool install --force --with 'claude-agent-sdk>=0.1.0' git+https://github.com/microsoft/conductor.git" >&2
  echo "         Or re-run the pack installer (install.sh), which installs uv + conductor for you." >&2
  exit 1
fi

exec conductor run "$wf" \
  --web --web-port "$web_port" \
  --input feature_slug="$slug" \
  --input feature="$slug" \
  --input prd_path="$prd" \
  --input model="$model_json" \
  "$@"
