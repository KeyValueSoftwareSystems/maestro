#!/usr/bin/env bash
# =============================================================================
# maestro — repo-local dev wrapper for the Maestro pack
# =============================================================================
# Two subcommands, both dev tooling. This wrapper NEVER drives a run or writes run
# state (.maestro/**/state.yaml) — the /maestro skill + engine remain the sole
# execution path and the only state writer.
#
#   maestro ui [--port N] [--no-open]   serve the visual builder from THIS repo:
#                                       auto-loads .maestro/workflows and .maestro/runs
#   maestro install [claude-code|cursor …]   (re)install the pack into this repo
#   maestro help | version
#
# install.sh drops this at your repo root as ./maestro. Run it as `./maestro ui`.
# =============================================================================
set -u

# --- resolve our own location (portable readlink -f; macOS/bash-3.2 safe) ----
resolve() {
  src="$1"
  while [ -h "$src" ]; do
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" && pwd
}
D=$(resolve "$0")

# MAESTRO_HOME holds engine/ + ui/. Env override wins; else the installed consumer
# layout (.maestro/ next to the wrapper at repo root), then a tree given directly, then
# the pack-repo layout (wrapper at bin/, engine/ui at the parent). install.sh is NOT
# under MAESTRO_HOME in a consumer — it sits at the repo root beside the wrapper.
if [ -n "${MAESTRO_HOME:-}" ]; then
  :
elif [ -f "$D/.maestro/engine/ui_server.py" ]; then
  MAESTRO_HOME="$D/.maestro"
elif [ -f "$D/engine/ui_server.py" ]; then
  MAESTRO_HOME="$D"
elif [ -f "$D/../engine/ui_server.py" ]; then
  MAESTRO_HOME=$(cd "$D/.." && pwd)
else
  echo "maestro: cannot locate the pack (no engine/ui_server.py under $D/.maestro or $D)." >&2
  echo "  set MAESTRO_HOME to the dir that holds engine/ and ui/." >&2
  exit 2
fi

usage() {
  sed -n '5,14p' "$0" | sed 's/^# \{0,1\}//'
}

cmd="${1:-help}"
[ $# -gt 0 ] && shift

case "$cmd" in
  ui)
    builder="$MAESTRO_HOME/ui/builder.html"
    [ -f "$PWD/.maestro/ui/builder.html" ] && builder="$PWD/.maestro/ui/builder.html"
    [ -f "$PWD/ui/builder.html" ] && builder="$PWD/ui/builder.html"
    exec python3 "$MAESTRO_HOME/engine/ui_server.py" \
      --root "$PWD" --builder "$builder" "$@"
    ;;
  install)
    # install.sh lives beside the wrapper at the repo root (consumer) or beside engine/
    # (pack repo) — check MAESTRO_HOME, then its parent, then the wrapper's own dir.
    inst="$MAESTRO_HOME/install.sh"
    [ -f "$inst" ] || inst="$MAESTRO_HOME/../install.sh"
    [ -f "$inst" ] || inst="$D/install.sh"
    if [ ! -f "$inst" ]; then
      echo "maestro: no install.sh near $MAESTRO_HOME" >&2; exit 2
    fi
    DEST="$PWD" exec bash "$inst" "$@"
    ;;
  version|--version|-v)
    echo "maestro (KeyValue AI-SDLC pack) — home: $MAESTRO_HOME"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "maestro: unknown command '$cmd'" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
